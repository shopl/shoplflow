{
  "name": "shoplflow",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:package": "turbo run build:package",
    "build:assets": "turbo run build:assets",
    "build:storybook": "turbo run build:storybook",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:storybook": "turbo run dev:storybook",
    "dev:stories": "turbo run dev:stories",
    "chromatic:base": "CHROMATIC_PROJECT_TOKEN=chpt_5ec3d4eebb0d91d pnpm --filter @shoplflow/base run chromatic",
    "dev": "turbo run dev",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clear:node_modules": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && rm -rf .pnpm-store",
    "refresh:node_modules": "pnpm run clear:node_modules && pnpm i",
    "refresh:pnpm": "rm -rf .pnpm-store && pnpm refresh:node_modules",
    "changeset": "changeset",
    "version": "pnpm changeset version && pnpm install --lockfile-only",
    "release": "pnpm changeset publish",
    "prepare": "husky install",
    "clear:branch": "scripts/delete-remote-branches.sh",
    "post-checkout": "pnpm run refresh:node_modules",
    "postinstall": "husky install && pnpm config set store-dir .pnpm-store"
  },
  "license": "Apache-2.0",
  "version": "0.0.1",
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@types/node": "^22.0.0",
    "@changesets/cli": "^2.29.8",
    "@vitest/coverage-v8": "^1.2.2",
    "esbuild": "0.18.17",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import-x": "^4.6.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^0.11.0",
    "eslint-plugin-unused-imports": "^4.1.0",
    "globals": "^15.14.0",
    "husky": "8.0.3",
    "jiti": "^2.6.1",
    "lint-staged": "13.2.3",
    "prettier": "^3.0.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^1.2.2"
  },
  "lint-staged": {
    "**.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "playwright-core": "1.58.2",
      "playwright": "1.58.2"
    }
  },
  "dependencies": {
    "@figma/code-connect": "^1.4.3"
  }
}
