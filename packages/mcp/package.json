{
  "name": "@shoplflow/mcp",
  "version": "0.0.0",
  "description": "Model Context Protocol server exposing the shoplflow design system (tokens, components, icons) to AI coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "shoplflow-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:metadata": "node scripts/generate-metadata.cjs",
    "build:package": "pnpm generate:metadata && rm -rf dist/ && tsup",
    "dev": "pnpm generate:metadata && tsup --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0",
    "tsup": "7.2.0",
    "typescript": "^5.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shopl/shoplflow",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/shopl/shoplflow#readme",
  "bugs": {
    "url": "https://github.com/shopl/shoplflow/issues"
  }
}
