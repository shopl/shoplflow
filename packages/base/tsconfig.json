{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // TS6: baseUrl 제거 (paths 미사용 · non-relative import 없음)
    "module": "esnext",
    "target": "es6",
    "allowJs": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/emotion.d.ts",
    "images.d.ts",
    "src"
  ],
  "exclude": [
    "src/styles/tokens/shoplColors.ts",
    "src/styles/tokens/hadaColors.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.figma.tsx",
    "*.json"
  ]
}
