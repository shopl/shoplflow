{
  "name": "@shoplflow/base",
  "version": "0.46.17",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/shopl/shoplflow",
    "directory": "packages/base"
  },
  "bugs": {
    "url": "https://github.com/shopl/shoplflow/issues"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build:tokens": "node scripts/generate-tokens.cjs",
    "build:package": "rm -rf dist/ && tsup",
    "generate:component": "scripts/generate-component.sh",
    "build:storybook": "storybook build",
    "build": "pnpm run build:package && pnpm run build:storybook",
    "chromatic": "chromatic --build-script-name=build:storybook",
    "dev:stories": "storybook dev -p 6007",
    "dev": "tsup --watch",
    "figma:parse": "npx figma connect parse",
    "figma:publish": "npx figma connect publish",
    "test": "vitest",
    "install:playwright": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers pnpm exec playwright install chromium",
    "test-storybook": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers test-storybook --url http://localhost:6007",
    "test-storybook:ci": "pnpm run build:storybook && npx concurrently -k -s first -n SB,TEST -c magenta,blue \"npx serve storybook-static --listen 6007\" \"npx wait-on tcp:127.0.0.1:6007 && pnpm run test-storybook\""
  },
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "require": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": "./src/styles/global.css",
    "./reset": "./src/styles/reset.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        },
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./styles": "./dist/styles/global.css",
      "./reset": "./dist/styles/reset.css",
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@babel/core": "^7.22.19",
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.22.15",
    "@emotion/babel-plugin": "^11.11.0",
    "@emotion/is-prop-valid": "^1.2.1",
    "@emotion/react": "11.10.8",
    "@emotion/styled": "11.10.8",
    "@mdx-js/react": "^3.0.0",
    "@mdx-js/rollup": "^3.0.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@storybook/addon-a11y": "^10.2.1",
    "@storybook/addon-designs": "^11.1.1",
    "@storybook/addon-docs": "^10.2.4",
    "@storybook/addon-links": "^10.2.1",
    "@storybook/addon-mcp": "^0.2.2",
    "@storybook/addon-themes": "^10.2.8",
    "@storybook/react-vite": "^10.2.1",
    "@types/node": "20.4.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.1",
    "chromatic": "^15.2.0",
    "classnames": "^2.3.2",
    "storybook": "^10.2.1",
    "@storybook/test-runner": "^0.24.2",
    "playwright": "1.58.2",
    "concurrently": "^9.1.0",
    "serve": "^14.2.4",
    "wait-on": "^8.0.1",
    "ts-node": "^10.9.1",
    "vitest": "^1.2.2",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/user-event": "^14.5.1",
    "jsdom": "^24.0.0",
    "tslib": "^2.6.2",
    "tsup": "7.2.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@figma/code-connect": "^1.4.3",
    "@floating-ui/core": "^1.5.0",
    "@floating-ui/react": "^0.26.2",
    "@floating-ui/react-dom": "^2.0.3",
    "@shoplflow/hada-assets": "workspace:^",
    "@shoplflow/shopl-assets": "workspace:^",
    "@shoplflow/utils": "workspace:^",
    "date-fns": "^3.6.0",
    "framer-motion": "10.12.6",
    "react": "^18.2.0",
    "react-custom-scrollbars-2": "^4.5.0",
    "react-datepicker": "^7.3.0",
    "react-dom": "^18.2.0",
    "simplebar-react": "^3.2.6"
  },
  "homepage": "https://github.com/shopl/shoplflow#readme"
}
