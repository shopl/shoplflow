  "files": [
    "/dist"
  ],
  "dependencies": {
    "@emotion/css": "11.11.2",
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@babel/preset-typescript": "^7.22.5",
    "@jest/globals": "^29.5.0",
    "@types/jest": "^29.5.2",
    "@types/react": "18.2.18",
    "@types/react-dom": "18.2.7",
    "esbuild": "^0.18.11",
    "esbuild-plugin-d.ts": "^1.1.0",
    "eslint": "^8.44.0",
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "jest-pnp-resolver": "^1.2.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
